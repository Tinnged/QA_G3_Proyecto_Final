<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MiBusCR.Models"
             x:Class="MiBusCR.InformacionRutasV2"
             x:Name="thisPage"
             Title="Ver Paradas"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *"
              BackgroundColor="White"
              Padding="15,12">
            <Button Grid.Column="0"
                    Text="&#8592;"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   x:Name="LblNombreRuta"
                   Text="Cargando ruta..."
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"
                   Margin="8,0,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Margin="15,16,15,30">

                <!-- Loading -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="#2563EB"
                                   HeightRequest="50"
                                   Margin="0,20,0,0"/>

                <!-- Lista de paradas -->
                <Border x:Name="BorderParadas"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="0"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="PARADAS DE LA RUTA"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#9CA3AF"
                               CharacterSpacing="1.5"
                               Margin="15,14,15,10"/>

                        <CollectionView x:Name="ListaParadasView"
                                        ItemsSource="{Binding ListaParadas}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ParadaRuta">

                                    <!-- ✅ Un solo hijo directo -->
                                    <VerticalStackLayout Spacing="0">

                                        <Grid ColumnDefinitions="Auto, *"
                                              Padding="15,0,15,0">

                                            <!-- Número de parada -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#EFF6FF"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    Padding="0"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding OrdenParada}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       TextColor="#2563EB"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <!-- Info parada -->
                                            <Grid Grid.Column="1"
                                                  ColumnDefinitions="*, Auto"
                                                  Margin="12,0,0,0"
                                                  Padding="0,14,0,14">

                                                <VerticalStackLayout Grid.Column="0"
                                                                     VerticalOptions="Center"
                                                                     Spacing="2">
                                                    <Label Text="{Binding DetalleParada.Nombre}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827"/>
                                                    <Label Text="Toca el pin para ver ubicación"
                                                           FontSize="12"
                                                           TextColor="#6B7280"/>
                                                </VerticalStackLayout>

                                                <ImageButton Grid.Column="1"
                                                             Source="map_pin.png"
                                                             HeightRequest="24"
                                                             WidthRequest="24"
                                                             Aspect="AspectFit"
                                                             VerticalOptions="Center"
                                                             Clicked="OnVerEnMapaClicked"
                                                             BackgroundColor="Transparent"/>
                                            </Grid>

                                        </Grid>

                                        <!-- Divider -->
                                        <BoxView HeightRequest="1"
                                                 Color="#F3F4F6"
                                                 Margin="15,0"
                                                 IsVisible="{Binding NoEsLaUltima}"/>

                                    </VerticalStackLayout>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label x:Name="LabelTotalParadas"
                               Text=""
                               FontSize="11"
                               TextColor="#9CA3AF"
                               HorizontalOptions="Center"
                               Margin="0,10,0,14"/>

                    </VerticalStackLayout>
                </Border>

                <!-- Error state -->
                <Border x:Name="BorderError"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="#FEF2F2"
                        Padding="15"
                        Stroke="#FECACA"
                        StrokeThickness="1"
                        IsVisible="False">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="⚠ No se pudo cargar las paradas"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#DC2626"
                               HorizontalOptions="Center"/>
                        <Label x:Name="LabelErrorMsg"
                               FontSize="13"
                               TextColor="#7F1D1D"
                               HorizontalOptions="Center"/>
                        <Button Text="Reintentar"
                                BackgroundColor="#DC2626"
                                TextColor="White"
                                CornerRadius="8"
                                Clicked="OnReintentarClicked"
                                Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>