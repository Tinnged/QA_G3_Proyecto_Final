<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiBusCR.AdminMainPanelV2"
             Title="Administrar Rutas"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *"
              BackgroundColor="White"
              Padding="15,12">
            <Button Grid.Column="0"
                    Text="&#8592;"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   Text="Administrar Rutas"
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"
                   Margin="8,0,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Margin="15,16,15,30">

                <!-- Admin Info Card -->
                <Border StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="20,18"
                        Stroke="#E5E7EB"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="LblNombreEmpresa"
                               Text="Cargando empresa..."
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Label x:Name="LblNombreAdmin"
                               Text="Cargando administrador..."
                               FontSize="14"
                               TextColor="#6B7280"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Acciones section label -->
                <Label Text="ACCIONES"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#9CA3AF"
                       CharacterSpacing="1.5"
                       Margin="4,0,0,0"/>

                <!-- Acciones card -->
                <Border StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="0"
                        Stroke="#E5E7EB"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="0">

                        <!-- Feedback de Usuarios -->
                        <Grid ColumnDefinitions="*, Auto"
                              Padding="15,14"
                              MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnFeedbackClicked"/>
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Feedback de Usuarios"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>
                                <Label Text="Ver reportes y opiniones de usuarios"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="#D1D5DB"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="15,0"/>

                        <!-- Crear Nueva Ruta -->
                        <Grid ColumnDefinitions="*, Auto"
                              Padding="15,14"
                              MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCrearRutaClicked"/>
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Grid.Column="0"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Crear Nueva Ruta"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>
                                <Label Text="Registrar una nueva ruta de autobús"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="#D1D5DB"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="15,0"/>

                        <!-- Agregar Paradas -->
                        <Grid ColumnDefinitions="*, Auto"
      Padding="15,14"
      MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnParadasClicked"/>
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Grid.Column="0"
                         VerticalOptions="Center"
                         Spacing="2">
                                <Label Text="Agregar Paradas a una Ruta"
               FontSize="15"
               FontAttributes="Bold"
               TextColor="#111827"/>
                                <Label Text="Agrega una nueva parada a una Ruta"
               FontSize="12"
               TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
           Text="›"
           FontSize="22"
           TextColor="#D1D5DB"
           VerticalOptions="Center"/>
                        </Grid>



                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>