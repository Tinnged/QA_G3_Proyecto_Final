<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiBusCR.PanelAdministrador"
             Title="Panel Administrador"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">

            <Label Text="Panel Administrador"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#111827"/>

            <Label Text="Crear una nueva ruta con sus coordenadas"
                   FontSize="16"
                   TextColor="#6B7280"/>

            <Frame BackgroundColor="White"
                   CornerRadius="18"
                   Padding="20"
                   HasShadow="True">
                <VerticalStackLayout Spacing="15">

                    <Label Text="Nombre de la ruta" FontAttributes="Bold" TextColor="Black"/>
                    <Entry x:Name="NombreRutaEntry" Placeholder="Ejemplo: Santa Ana - Escazu"/>

                    <Label Text="Provincia inicio" FontAttributes="Bold" TextColor="Black"/>
                    <Entry x:Name="ProvinciaInicioEntry" Placeholder="Ejemplo: San Jose"/>

                    <Label Text="Provincia final" FontAttributes="Bold" TextColor="Black"/>
                    <Entry x:Name="ProvinciaFinalEntry" Placeholder="Ejemplo: Alajuela"/>

                    <Label Text="Destino" FontAttributes="Bold" TextColor="Black"/>
                    <Entry x:Name="DestinoEntry" Placeholder="Ejemplo: Terminal Escazu"/>

                    <Label Text="Tarifa" FontAttributes="Bold" TextColor="Black"/>
                    <Entry x:Name="MontoTarifaEntry" Placeholder="Ejemplo: 550" Keyboard="Numeric"/>

                    <Label Text="Métodos de pago" FontAttributes="Bold" TextColor="Black"/>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="CheckEfectivo" Color="#2563EB"/>
                        <Label Text="Efectivo" VerticalOptions="Center" TextColor="Black"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="CheckTarjeta" Color="#2563EB"/>
                        <Label Text="Tarjeta" VerticalOptions="Center" TextColor="Black"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <CheckBox x:Name="CheckSinpe" Color="#2563EB"/>
                        <Label Text="SINPE Móvil" VerticalOptions="Center" TextColor="Black"/>
                    </HorizontalStackLayout>

                    <Button Text="Guardar ruta"
                            Background="#2563EB"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="50"
                            Clicked="OnGuardarRutaClicked"/>

                    <Label x:Name="MensajeLabel"
                           Text=""
                           FontAttributes="Bold"
                           IsVisible="False"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>