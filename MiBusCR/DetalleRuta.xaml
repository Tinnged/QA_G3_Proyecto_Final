<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MiBusCR.DetalleRuta"
             Title="Detalle de Ruta"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, *">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *"
              BackgroundColor="White"
              Padding="15,12">
            <Button Grid.Column="0"
                    Text="&#8592;"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    TextColor="#111827"
                    Padding="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Clicked="OnBackClicked"/>
            <Label Grid.Column="1"
                   Text="Detalle de Ruta"
                   FontSize="17"
                   FontAttributes="Bold"
                   TextColor="#111827"
                   VerticalOptions="Center"
                   Margin="8,0,0,0"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Margin="15,16,15,30">

                <!-- Ruta seleccionada card -->
                <Border StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="20,18"
                        Stroke="#E5E7EB"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="LblNombreRuta"
                               Text="Ruta seleccionada"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#111827"/>
                        <Label x:Name="LabelEstadoRuta"
                               Text="Estado: Activa"
                               FontSize="14"
                               TextColor="#6B7280"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Acciones section -->
                <Label Text="ACCIONES"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#9CA3AF"
                       CharacterSpacing="1.5"
                       Margin="4,0,0,0"/>

                <!-- Acciones card -->
                <Border StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="0"
                        Stroke="#E5E7EB"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="0">

                        <!-- Tarifas y Métodos de Pago -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              Padding="15,14"
                              MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTarifasClicked"/>
                            </Grid.GestureRecognizers>

                            <!-- Icon container -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#EEF2FF"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0">
                                <Label Text="₡"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="#4F46E5"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Text -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="14,0,0,0"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Tarifas y Métodos de Pago"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>
                                <Label Text="Consultar tarifa vigente y formas de pago"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <!-- Chevron -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="#D1D5DB"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                 Color="#F3F4F6"
                                 Margin="15,0"/>

                        <!-- Reportar un Problema -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
                              Padding="15,14"
                              MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReportarClicked"/>
                            </Grid.GestureRecognizers>

                            <!-- Icon container -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#FEF9C3"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0">
                                <Label Text="⚠"
                                       FontSize="20"
                                       TextColor="#CA8A04"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Text -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Margin="14,0,0,0"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Reportar un Problema"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="#111827"/>
                                <Label Text="Enviar feedback sobre una ruta"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <!-- Chevron -->
                            <Label Grid.Column="2"
                                   Text="›"
                                   FontSize="22"
                                   TextColor="#D1D5DB"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="15,0"/>

                        <!-- Ver Paradas -->
                        <Grid ColumnDefinitions="Auto, *, Auto"
      Padding="15,14"
      MinimumHeightRequest="64">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnVerParadasClicked"/>
                            </Grid.GestureRecognizers>

                            <Border Grid.Column="0"
            BackgroundColor="#F0FDF4"
            StrokeShape="RoundRectangle 10"
            Stroke="Transparent"
            WidthRequest="44"
            HeightRequest="44"
            Padding="0">
                                <Label Text="🗺️"
               FontSize="20"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1"
                         Margin="14,0,0,0"
                         VerticalOptions="Center"
                         Spacing="2">
                                <Label Text="Ver Paradas"
               FontSize="15"
               FontAttributes="Bold"
               TextColor="#111827"/>
                                <Label Text="Visualizar el recorrido de la ruta"
               FontSize="12"
               TextColor="#6B7280"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
           Text="›"
           FontSize="22"
           TextColor="#D1D5DB"
           VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>