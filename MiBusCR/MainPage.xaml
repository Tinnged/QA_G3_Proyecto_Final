<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MiBusCR.Models"
             x:Class="MiBusCR.MainPage"
             Title="MiBusCR"
             x:Name="thisPage"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto"
              BackgroundColor="White"
              Padding="15,14">
            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Label Text="MiBusCR"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#111827"/>
                <Label x:Name="PruebaZe"
                       Text="Conectando..."
                       FontSize="12"
                       TextColor="#6B7280"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="Administradores"
                    FontSize="12"
                    BackgroundColor="#F3F4F6"
                    TextColor="#6B7280"
                    CornerRadius="8"
                    Padding="10,6"
                    HeightRequest="35"
                    VerticalOptions="Center"
                    Clicked="OnAdminClicked"/>
        </Grid>

        <!-- SearchBar -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                Margin="15,12,15,4"
                Padding="4,0">
            <SearchBar Placeholder="Buscar por ruta o provincia..."
                       TextChanged="OnSearchBarTextChanged"
                       BackgroundColor="Transparent"/>
        </Border>

        <!-- Lista de rutas -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Source={x:Reference thisPage}, Path=RutasAMostrar}"
                        Margin="15,8,15,20">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Ruta">
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="White"
                            Padding="16"
                            Stroke="#E5E7EB"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="10">

                            <!-- Nombre + Badge Activa -->
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding Nombre}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#111827"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#DEF7EC"
                                        StrokeShape="RoundRectangle 20"
                                        Stroke="Transparent"
                                        Padding="10,4">
                                    <Label Text="Activa"
                                           TextColor="#059669"
                                           FontAttributes="Bold"
                                           FontSize="11"/>
                                </Border>
                            </Grid>



                            <!-- Tarifa -->
                            <Label Text="{Binding MontoTarifa, StringFormat='₡{0:N0}'}"
                                   TextColor="#059669"
                                   FontAttributes="Bold"
                                   FontSize="17"/>

                            <!-- Badges métodos de pago -->
                            <FlexLayout Wrap="Wrap" Direction="Row">
                                <Border BackgroundColor="#DCFCE7"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,4"
                                        Margin="0,0,6,0"
                                        IsVisible="{Binding AceptaEfectivo}">
                                    <Label Text="Efectivo"
                                           FontSize="11"
                                           TextColor="#166534"/>
                                </Border>
                                <Border BackgroundColor="#DBEAFE"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,4"
                                        Margin="0,0,6,0"
                                        IsVisible="{Binding AceptaTarjeta}">
                                    <Label Text="Tarjeta"
                                           FontSize="11"
                                           TextColor="#1D4ED8"/>
                                </Border>
                                <Border BackgroundColor="#FFEDD5"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="Transparent"
                                        Padding="8,4"
                                        Margin="0,0,6,0"
                                        IsVisible="{Binding AceptaSinpe}">
                                    <Label Text="SINPE"
                                           FontSize="11"
                                           TextColor="#9A3412"/>
                                </Border>
                            </FlexLayout>

                            <!-- Ver detalles -->
                            <Button Text="Ver detalles de la ruta"
        BackgroundColor="#2563EB"
        TextColor="White"
        CornerRadius="8"
        FontAttributes="Bold"
        Margin="0,4,0,0"
        Clicked="OnVerRutasClicked"
        BindingContext="{Binding .}"/>
                            

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>